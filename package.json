{
  "name": "flare-studio",
  "version": "0.0.1",
  "description": "Flare studio is a graphical user interface for Flare Engine which aims to improve the user experience of the engine and encourage users to make more games with Flare Engine. Flare Studio is at its the Alpha Stage — expect incomplete features and active development and use it with your own risk.",
  "main": "electron/main.cjs",
  "homepage": "./",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron-dev": "concurrently \"vite --port 5175\" \"wait-on http://localhost:5175 && electron .\"",
    "electron-build": "npm run build && electron-builder",
    "go": "concurrently \"vite --port 5179\" \"wait-on http://localhost:5179 && electron .\"",
  "pack": "electron-builder --dir",
  "dist": "npm run build && electron-builder --win",
  "dist:win": "npm run build && electron-builder --win",
  "dist:linux": "npm run build && electron-builder --linux",
  "dist:mac": "npm run build && electron-builder --mac",
    "electron-dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron-build": "npm run build && electron-builder",
    "go": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toast": "^1.2.15",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "lucide-react": "^0.542.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "lucide-react": "^0.284.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^1.14.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.0",
    "electron": "^26.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "electron-builder": "^24.0.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.2.0",
    "vite": "^5.0.0",
    "wait-on": "^7.0.0"
  },
  "build": {
    "appId": "com.ismtile.editor",
    "productName": "Flare Studio",
    "directories": {
      "output": "release",
      "buildResources": "build",
    "productName": "Isometric Tile Editor",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "!**/*.map"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icons/flare.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icons/flare.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icons/flare.png"
    },
    "extraResources": [
      {
        "from": "public",
        "to": "public",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/icons",
        "to": "icons",
        "filter": [
          "**/*"
        ]
      }
    ]
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "keywords": [
    "tilemap",
    "editor",
    "isometric",
    "typescript",
    "react",
    "tailwind",
    "electron"
  ],
  "author": "",
  "license": "MIT"
}
