{
  "css.validate": false,
  "scss.validate": false,
  "less.validate": false,
  "css.lint.unknownAtRules": "ignore",
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "emmet.includeLanguages": {
    "javascript": "javascriptreact"
  },
  "editor.quickSuggestions": {
    "strings": true
  },
  "tailwindCSS.includeLanguages": {
    "html": "html",
    "javascript": "javascript",
    "css": "css"
  },
  "tailwindCSS.emmetCompletions": true,
  "chatgpt.openOnStartup": false,
  "mcp.autoStart": true,
  "mcp.startOnStartup": true,
  "mcp.autoStartServers": [
    "oraios/serena",
    "io.github.ChromeDevTools/chrome-devtools-mcp",
    "io.github.github/github-mcp-server",
    "io.github.upstash/context7",
    "io.github.wonderwhy-er/desktop-commander",
    "io.github.brightdata/brightdata-mcp",
    "microsoft/playwright-mcp"
  ],
  "terminal.integrated.defaultProfile.linux": "bash",
  "workbench.colorCustomizations": {
    "editor.lineHighlightBackground": "#1073cf2d",
    "editor.lineHighlightBorder": "#9fced11f",
    "activityBar.background": "#411F4F",
    "titleBar.activeBackground": "#5B2B6F",
    "titleBar.activeForeground": "#FDFBFD",
    "titleBar.inactiveBackground": "#411F4F",
    "titleBar.inactiveForeground": "#FDFBFD",
    "statusBar.background": "#411F4F",
    "statusBar.foreground": "#FDFBFD",
    "statusBar.debuggingBackground": "#411F4F",
    "statusBar.debuggingForeground": "#FDFBFD",
    "statusBar.noFolderBackground": "#411F4F",
    "statusBar.noFolderForeground": "#FDFBFD"
  },
  "windowColors.baseColor": "#8e44ad"
}
